{
  "name": "border-beam-vanilla",
  "version": "1.0.1",
  "description": "Animated border beam effect for Vanilla JavaScript",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "keywords": [
    "javascript",
    "typescript",
    "vanilla-js",
    "animation",
    "border",
    "beam",
    "glow",
    "effect",
    "css"
  ],
  "author": "jqueryscript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jqueryscript/border-beam-vanilla.git"
  },
  "bugs": {
    "url": "https://github.com/jqueryscript/border-beam-vanilla/issues"
  },
  "homepage": "https://www.cssscript.com/border-beam-vanilla/"
}
